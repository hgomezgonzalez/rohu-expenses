# ROHU PayControl - Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_NAME=rohu-paycontrol
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://paycontrol:paycontrol@localhost:5432/paycontrol
DATABASE_URL_SYNC=postgresql://paycontrol:paycontrol@localhost:5432/paycontrol

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Email (SMTP for sending)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@paycontrol.local
SMTP_FROM_NAME=ROHU PayControl
SMTP_TLS=false

# Notifications
NOTIFICATION_QUIET_HOURS_START=22
NOTIFICATION_QUIET_HOURS_END=7

# Telegram Bot (create via @BotFather, get chat_id via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# WebAuthn / Passkeys (biometric login)
# WEBAUTHN_RP_ID = registered domain WITHOUT scheme/port (e.g. paycontrol.example.com).
# Use "localhost" for local development.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=ROHU PayControl
# Comma-separated list of allowed origins (must include https:// in prod).
WEBAUTHN_ORIGINS=http://localhost:3000
WEBAUTHN_CHALLENGE_TTL_SECONDS=300
